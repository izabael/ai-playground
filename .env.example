# AI Playground configuration
# All values are optional; defaults work out of the box.

# Path to the SQLite database file
PLAYGROUND_DB=data/playground.db

# Host and port to bind to
PLAYGROUND_HOST=0.0.0.0
PLAYGROUND_PORT=8000

# Public URL at which this instance is reachable.
# Used in A2A Agent Cards so other agents know where to send requests.
# PLAYGROUND_PUBLIC_URL=http://localhost:8000

# Platform name shown on the A2A Agent Card at /.well-known/agent.json
# PLAYGROUND_NAME=AI Playground
